# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_service_role_key

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long

# Server Configuration
PORT=5000
NODE_ENV=development

EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false

EMAIL_USER=apikey
EMAIL_PASSWORD=YOUR_SENDGRID_API_KEY

OPENCAGE_API_KEY=your_api_key_here

EMAIL_FROM=your_email@gmail.com
APP_URL=http://10.190.72.164:5000

# OpenRouteService API key for route optimization
OPENROUTESERVICE_API_KEY=your_key_here   # Get free key at openrouteservice.org
DEPOT_LAT=4.1537                          # Starting point latitude (e.g. municipal yard)
DEPOT_LNG=9.2685                          # Starting point longitude
